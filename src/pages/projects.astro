---
import Sidebar from '../components/Sidebar.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Projects | Matt Carey"
  description="Creator of Shippie, an extensible AI code review tool, founding team at Quivr (YC W24), and ParliamentWow."
>
  <Sidebar />
  <main class="flex-auto min-w-0 mt-6 md:mt-0 flex flex-col px-2 md:px-0">
    <section>
      <h1 class="font-bold text-3xl font-serif mb-8">Projects</h1>
      <div class="space-y-6">
        <div class="flex items-baseline gap-8">
          <span
            class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]"
          >
            2025 - Present
          </span>
          <div>
            <a
              href="https://bad-agent.transistor.fm/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
              >You've Been a Bad Agent</a
            >
            <span
              class="italic text-xs text-neutral-400 dark:text-neutral-500 ml-2"
              >(podcast)</span
            >
            <span class="text-neutral-600 dark:text-neutral-400 ml-2"
              >- Wil and Matt discuss tech, startups, and building really cool
              things with AI. Sometimes joined by (actual expert) friends.</span
            >
          </div>
        </div>

        <div class="flex items-baseline gap-8">
          <span
            class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]"
          >
            2025 - Present
          </span>
          <div>
            <a
              href="https://github.com/modelcontextprotocol/typescript-sdk"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
              >Model Context Protocol</a
            >
            <span
              class="italic text-xs text-neutral-400 dark:text-neutral-500 ml-2"
              >(open source)</span
            >
            <span class="text-neutral-600 dark:text-neutral-400 ml-2"
              >- maintainer of the TypeScript SDK.</span
            >
          </div>
        </div>

        <div class="flex items-baseline gap-8">
          <span
            class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]"
          >
            2024 - Present
          </span>
          <div>
            <a
              href="https://lu.ma/ai-demo-days"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
              >AI Demo Days</a
            >
            <span
              class="italic text-xs text-neutral-400 dark:text-neutral-500 ml-2"
              >(events)</span
            >
            <span class="text-neutral-600 dark:text-neutral-400 ml-2"
              >- the best place to see new AI tech globally, events in London, SF,
              NYC, Stockholm..</span
            >
          </div>
        </div>

        <div class="flex items-baseline gap-8">
          <span
            class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]"
          >
            2024 - 2025
          </span>
          <div>
            <a
              href="https://openuk.uk/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
              >OpenUK AI Advisory Board</a
            >
            <span
              class="italic text-xs text-neutral-400 dark:text-neutral-500 ml-2"
              >(open source)</span
            >
            <span class="text-neutral-600 dark:text-neutral-400 ml-2"
              >- got to speak to some important people about AI.</span
            >
          </div>
        </div>

        <div class="flex items-baseline gap-8">
          <span
            class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]"
          >
            2022 - 2025
          </span>
          <div>
            <a
              href="https://github.com/mattzcarey/shippie"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
              >Shippie</a
            >
            <span
              class="italic text-xs text-neutral-400 dark:text-neutral-500 ml-2"
              >(open source)</span
            >
            <span class="text-neutral-600 dark:text-neutral-400 ml-2"
              >- extensible AI code review tool</span
            >
          </div>
        </div>

        <div class="flex items-baseline gap-8">
          <span
            class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]"
          >
            2024 - 2024
          </span>
          <div>
            <a
              href="https://parliamentwow.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
              >ParliamentWow</a
            >
            <span
              class="italic text-xs text-neutral-400 dark:text-neutral-500 ml-2"
              >(hackathon)</span
            >
            <span class="text-neutral-600 dark:text-neutral-400 ml-2"
              >- unpicking what actually happens in parliament. Winner of a16z
              Hack UK October 2024 with Sunil Pai and Thomas Ankcorn.</span
            >
          </div>
        </div>

        <div class="flex items-baseline gap-8">
          <span
            class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]"
          >
            2023 - 2023
          </span>
          <div>
            <a
              href="https://www.quivr.app"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
              >Quivr (YC W24)</a
            >
            <span
              class="italic text-xs text-neutral-400 dark:text-neutral-500 ml-2"
              >(open source)</span
            >
            <span class="text-neutral-600 dark:text-neutral-400 ml-2"
              >- founding team member</span
            >
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
